{
  "name": "mm-rag-e",
  "version": "1.0.2",
  "description": "MultiModal RAG Enterprise (MM-RAG-E) using Gemini, Node.js, and Endee Vector DB",
  "main": "Backend/server.js",
  "scripts": {
    "start": "node Backend/server.js",
    "dev:backend": "nodemon Backend/server.js",
    "dev:frontend": "cd Frontend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "install:all": "npm install && cd Frontend && npm install"
  },
  "keywords": [
    "RAG",
    "Endee",
    "MultiModal",
    "AI",
    "Gemini",
    "Gemma",
    "Enterprise"
  ],
  "author": "Candidate",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "endee": "^1.6.1",
    "express": "^4.18.2",
    "mammoth": "^1.6.0",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "uuid": "^9.0.1"
  }
}
